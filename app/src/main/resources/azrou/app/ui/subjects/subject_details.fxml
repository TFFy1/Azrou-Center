<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="azrou.app.ui.subjects.SubjectDetailsController">
    <top>
        <VBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-padding: 15;">
            <Label fx:id="subjectTitleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Subject Details" />
            <Label fx:id="groupLabel" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" text="Group: " />
        </VBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Assessments">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="assessmentNameField" promptText="Assessment Name" />
                            <DatePicker fx:id="assessmentDatePicker" promptText="Date" />
                            <TextField fx:id="maxScoreField" promptText="Max Score" prefWidth="80" />
                            <TextField fx:id="weightField" promptText="Weight" prefWidth="60" />
                            <Button fx:id="addAssessmentButton" onAction="#handleAddAssessment" text="Add" />
                            <Button fx:id="updateAssessmentButton" onAction="#handleUpdateAssessment" text="Update" disable="true"/>
                            <Button fx:id="deleteAssessmentButton" onAction="#handleDeleteAssessment" text="Delete" disable="true"/>
                            <Button onAction="#handleClearAssessment" text="Clear" />
                        </HBox>
                        <TableView fx:id="assessmentsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="assessmentNameColumn" text="Name" />
                                <TableColumn fx:id="assessmentDateColumn" text="Date" />
                                <TableColumn fx:id="maxScoreColumn" text="Max Score" />
                                <TableColumn fx:id="weightColumn" text="Weight" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </Tab>
                <Tab text="Grades">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Select Assessment:" />
                            <ComboBox fx:id="assessmentCombo" prefWidth="200" />
                        </HBox>
                        <TableView fx:id="gradesTable" VBox.vgrow="ALWAYS" editable="true">
                            <columns>
                                <TableColumn fx:id="studentNameColumn" text="Student" />
                                <TableColumn fx:id="gradeScoreColumn" text="Score" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button fx:id="saveGradesButton" onAction="#handleSaveGrades" text="Save Grades" />
                        </HBox>
                    </VBox>
                </Tab>
                <Tab text="Absences">
                    <VBox spacing="10" style="-fx-padding: 10;">
                         <HBox spacing="10" alignment="CENTER_LEFT">
                            <ComboBox fx:id="studentCombo" promptText="Student" />
                            <DatePicker fx:id="absenceDatePicker" promptText="Date" />
                            <TextField fx:id="reasonField" promptText="Reason" HBox.hgrow="ALWAYS"/>
                            <Button fx:id="addAbsenceButton" onAction="#handleAddAbsence" text="Add" />
                             <Button fx:id="deleteAbsenceButton" onAction="#handleDeleteAbsence" text="Delete" disable="true"/>
                        </HBox>
                        <TableView fx:id="absencesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="absenceDateColumn" text="Date" />
                                <TableColumn fx:id="absenceStudentColumn" text="Student" />
                                <TableColumn fx:id="absenceReasonColumn" text="Reason" />
                                <TableColumn fx:id="absenceJustifiedColumn" text="Justified" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
