<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainLayout" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="azrou.app.ui.main.MainController">
   <left>
      <VBox fx:id="sideMenu" prefWidth="200.0" spacing="10.0" style="-fx-background-color: #f0f0f0;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
         </padding>
         <children>
            <Label text="Azrou Center" textFill="#2c3e50">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            <Button fx:id="studentsButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showStudents" text="Students" />
            <Button fx:id="groupsButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showGroups" text="Groups" />
            <Button fx:id="subjectsButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showSubjects" text="Subjects" />
            <Button fx:id="teachersButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showTeachers" text="Teachers" />
            <Separator prefWidth="200.0" />
            <Button fx:id="assessmentsButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showAssessments" text="Assessments" />
            <Button fx:id="gradesButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showGrades" text="Grades" />
            <Button fx:id="absencesButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showAbsences" text="Absences" />
            <Separator prefWidth="200.0" />
            <Button fx:id="importButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showImport" text="Import CSV" />
            <Button fx:id="backupButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showBackup" text="Backup &amp; Restore" />
            <Button fx:id="reportsButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showReports" text="Reports" />
            <Separator prefHeight="20.0" visible="false" VBox.vgrow="ALWAYS" />
            <Label fx:id="userLabel" text="User: Admin" />
            <Button fx:id="logoutButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" text="Logout" />
         </children>
      </VBox>
   </left>
   <center>
      <Label text="Welcome to Azrou Center App" BorderPane.alignment="CENTER">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
   </center>
</BorderPane>
