<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="azrou.app.ui.students.StudentController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label fx:id="titleLabel" text="Students">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <Label text="Filter by Group:" />
        <ComboBox fx:id="groupFilterCombo" prefWidth="200.0" />
    </HBox>
    
    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <TableView fx:id="studentsTable" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="cinColumn" text="CIN" />
                <TableColumn fx:id="nameColumn" text="Full Name" />
                <TableColumn fx:id="groupColumn" text="Group" />
                <TableColumn fx:id="phoneColumn" text="Phone" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
        
        <VBox spacing="10.0" minWidth="350.0">
            <HBox spacing="10.0" alignment="TOP_CENTER">
                <ImageView fx:id="photoView" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" style="-fx-border-color: gray;" />
            </HBox>
            <Button fx:id="uploadPhotoButton" text="Upload Photo" maxWidth="Infinity" onAction="#handleUploadPhoto" />
            
            <Label text="Group" />
            <ComboBox fx:id="groupCombo" maxWidth="Infinity" />
            
            <Label text="Full Name" />
            <TextField fx:id="fullNameField" />
            
            <Label text="CIN" />
            <TextField fx:id="cinField" />
            
            <Label text="Date of Birth" />
            <DatePicker fx:id="dobPicker" maxWidth="Infinity" />
            
            <Label text="Phone" />
            <TextField fx:id="phoneField" />
            
            <Label text="Qualifications" />
            <TextArea fx:id="qualificationsField" prefRowCount="3" />
            
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Button fx:id="clearButton" text="Clear" onAction="#handleClear" />
                <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete" style="-fx-background-color: #ffcccc;" />
                <Button fx:id="updateButton" text="Update" onAction="#handleUpdate" />
                <Button fx:id="addButton" text="Add" defaultButton="true" onAction="#handleAdd" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
