<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="azrou.app.ui.grades.GradeController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <Label fx:id="titleLabel" text="Grades Entry">
        <font>
            <Font size="24.0" />
        </font>
    </Label>
    
    <HBox spacing="20.0" alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label text="Group" />
            <ComboBox fx:id="groupCombo" prefWidth="200.0" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Subject" />
            <ComboBox fx:id="subjectCombo" prefWidth="200.0" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="Assessment" />
            <ComboBox fx:id="assessmentCombo" prefWidth="250.0" />
        </VBox>
        <Button fx:id="saveButton" text="Save Grades" onAction="#handleSave" prefHeight="30.0" style="-fx-base: #ccffcc;">
            <HBox.margin>
                <Insets top="20.0" />
            </HBox.margin>
        </Button>
    </HBox>
    
    <TableView fx:id="gradesTable" VBox.vgrow="ALWAYS" editable="true">
        <columns>
            <TableColumn fx:id="cinColumn" text="CIN" prefWidth="100.0" />
            <TableColumn fx:id="studentNameColumn" text="Student Name" prefWidth="250.0" />
            <TableColumn fx:id="scoreColumn" text="Score" prefWidth="100.0" />
        </columns>
    </TableView>
</VBox>
